# Server Configuration
PORT=3000

# Legacy single-target mode (optional if using named targets)
# TARGET_URL=https://api.example.com

# Authentication Token (optional - if not set, authentication is disabled)
# Can be sent via X-Forward-Token header OR as ?token=xxx query parameter
# AUTH_TOKEN=your_secret_token_here

# Forward Path (optional - default: true, only for legacy TARGET_URL)
# Set to false for fixed webhook URLs that don't accept additional paths
# FORWARD_PATH=true

# ============================================
# Named Targets (recommended)
# ============================================
# Each target gets its own dedicated port and forwards to its own upstream.
# Supports virtual host routing (like nginx server_name).
#
# Pattern:
#   TARGET_{NAME}_URL       - Upstream URL (required)
#   TARGET_{NAME}_PORT      - Listening port (required)
#   TARGET_{NAME}_HOST      - Virtual hosts, comma-separated (optional, like nginx server_name)
#   TARGET_{NAME}_AUTH      - Per-target auth token (optional)
#   TARGET_{NAME}_FWDPATH   - Forward path toggle (default: true)
#
# Example: API target on port 3001
# TARGET_API_URL=https://api.example.com
# TARGET_API_PORT=3001
# TARGET_API_HOST=api.example.com,api.local
# TARGET_API_AUTH=my_secret
# TARGET_API_FWDPATH=true
#
# Example: Webhook target on port 3002 (fixed URL, no path forwarding)
# TARGET_WEBHOOK_URL=https://hooks.example.com/webhook/abc123
# TARGET_WEBHOOK_PORT=3002
# TARGET_WEBHOOK_FWDPATH=false
#
# Example: Multi-site with virtual hosts (DNS-based routing like nginx)
# TARGET_SITE1_URL=https://backend1.internal
# TARGET_SITE1_PORT=8080
# TARGET_SITE1_HOST=site1.example.com,www.site1.example.com
#
# TARGET_SITE2_URL=https://backend2.internal
# TARGET_SITE2_PORT=8081
# TARGET_SITE2_HOST=site2.example.com,*.site2.example.com

# ============================================
# Proxy Bypass Profiles (optional)
# ============================================
# Create public links that bypass upstream authentication.
# These always run on the main PORT alongside the dashboard.
#
# Pattern:
#   PROXY_{NAME}_URL     - Base URL of the upstream service (required)
#   PROXY_{NAME}_KEY     - API key for the upstream service
#   PROXY_{NAME}_HEADER  - Header name for the API key
#   PROXY_{NAME}_PREFIX  - Optional auth prefix (e.g., "Bearer", "App")
#   PROXY_{NAME}_ACCESS  - Optional access key to protect public links
#   PROXY_{NAME}_BLOCKED - Comma-separated blocked file extensions
#
# Usage: GET /proxy/{name}/path/to/resource
#
# Example:
# PROXY_INFOBIP_URL=https://api.infobip.com
# PROXY_INFOBIP_KEY=your_infobip_api_key
# PROXY_INFOBIP_HEADER=Authorization
# PROXY_INFOBIP_PREFIX=App
# PROXY_INFOBIP_ACCESS=shared_secret
# PROXY_INFOBIP_BLOCKED=.exe,.bat,.sh

# ============================================
# Request Logging (optional)
# ============================================
# Full request/response logging with payload capture (SQLite).
# Logs are stored in DATA_DIR/request-logs.db
# REQUEST_LOG_ENABLED=true              # Default: true (set to false to disable)
# REQUEST_LOG_RETENTION_DAYS=7          # Auto-purge logs older than N days (default: 7)
# REQUEST_LOG_MAX_BODY_SIZE=65536       # Max body bytes to capture per request (default: 64KB)

# ============================================
# Persistence (optional)
# ============================================
# Directory for persistent data (profiles.json, targets.json, request-logs.db).
# In Docker, mount a volume here to persist across restarts.
# Default: ./data
# DATA_DIR=/data
